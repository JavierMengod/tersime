          },
          "query": "monthly_sum = \r\n  from(bucket: v.defaultBucket)\r\n    |> range(start: 0, stop: now())\r\n    |> filter(fn: (r) =>\r\n         r._measurement == \"hourly\" and\r\n         r._field == \"kwh\" and\r\n         r.name =~ /^(${dispositivos:regex})$/\r\n       )\r\n    |> group(columns: [\"name\"])\r\n    |> aggregateWindow(every: 1mo, fn: sum, createEmpty: true)\r\n    |> keep(columns: [\"_time\", \"name\", \"_value\"])\r\n    |> rename(columns: {_value: \"monthly_sum\"})\r\n\r\nmonthly_count_flag =\r\n  from(bucket: v.defaultBucket)\r\n    |> range(start: 0, stop: now())\r\n    |> filter(fn: (r) =>\r\n         r._measurement == \"hourly\" and\r\n         r._field == \"kwh\" and\r\n         r.name =~ /^(${dispositivos:regex})$/\r\n       )\r\n    |> group(columns: [\"name\"])\r\n    |> aggregateWindow(every: 1mo, fn: count, createEmpty: true)\r\n    |> keep(columns: [\"_time\", \"name\", \"_value\"])\r\n    |> rename(columns: {_value: \"has_count\"})\r\n    |> map(fn: (r) => ({\r\n         _time: r._time,\r\n         name: r.name,\r\n         has_count: if r.has_count > 0 then 1 else 0\r\n       }))\r\n    |> cumulativeSum(columns: [\"has_count\"])\r\n    |> rename(columns: {has_count: \"seen\"})\r\n\r\njoined =\r\n  join(\r\n    tables: {s: monthly_sum, v: monthly_count_flag},\r\n    on: [\"_time\", \"name\"],\r\n    method: \"inner\"\r\n  )\r\n  |> map(fn: (r) => ({\r\n       _time: r._time,\r\n       name: r.name,\r\n       monthly_sum: r.monthly_sum,\r\n       seen: r.seen\r\n     }))\r\n\r\nresult_ready =\r\n  joined\r\n    |> filter(fn: (r) => r.seen > 0)\r\n    |> map(fn: (r) => ({ _time: r._time, name: r.name, _value: r.monthly_sum }))\r\n\r\nresult_ready\r\n  |> group(columns: [\"name\"])\r\n  |> difference(nonNegative: false, columns: [\"_value\"])\r\n  |> map(fn: (r) => ({ _time: r._time, name: r.name, _value: r._value }))\r\n  |> yield(name: \"monthly_variation\")\r\n",
          "refId": "A"
        }
      ],
      "title": "Variación de Consumo Mensual",
