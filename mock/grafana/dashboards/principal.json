          },
          "query": "threshold = 0.1\r\n\r\nfrom(bucket: v.defaultBucket)\r\n  |> range(start: -7d, stop: now())\r\n  |> filter(fn: (r) =>\r\n      exists r.name and\r\n      r._measurement == \"hourly\" and\r\n      r._field == \"kwh\" and\r\n      r.name != \"total\" and\r\n      r.name =~ /^(${dispositivos:regex})$/\r\n  )\r\n  |> map(fn: (r) => ({ _time: r._time, name: r.name, active_hour: if r._value > threshold then 1 else 0 }))\r\n  |> group(columns: [\"name\"])\r\n  |> sum(column: \"active_hour\")\r\n  |> map(fn: (r) => ({ _time: now(), name: r.name, _value: r.active_hour }))\r\n  |> group()\r\n  |> sort(columns: [\"_value\"], desc: true)\r\n  |> keep(columns: [\"name\", \"_value\"])\r\n  |> yield(name: \"duty_cycle_hours_sorted\")\r\n",
          "refId": "A"
        }
      ],
      "title": "Horas Activas",
