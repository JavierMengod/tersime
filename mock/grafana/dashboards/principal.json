      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "feg5i5n3pjq4gf"
          },
          "query": "hourly = from(bucket: v.defaultBucket)\r\n  |> range(start: -7d)\r\n  |> filter(fn: (r) =>\r\n      r._measurement == \"hourly\" and\r\n      r._field == \"kwh\" and\r\n      r.name =~ /^(${dispositivos:regex})$/\r\n  )\r\n  |> keep(columns: [\"_time\", \"_value\", \"name\"])\r\n\r\nmean_values =\r\n  hourly\r\n    |> group(columns: [\"name\"])\r\n    |> mean(column: \"_value\")\r\n    |> rename(columns: {_value: \"mean_kwh\"})\r\n\r\nmax_values =\r\n  hourly\r\n    |> group(columns: [\"name\"])\r\n    |> max(column: \"_value\")\r\n    |> rename(columns: {_value: \"max_kwh\"})\r\n\r\njoin(\r\n    tables: {mean: mean_values, max: max_values},\r\n    on: [\"name\"]\r\n)\r\n  |> map(fn: (r) => ({\r\n        name: r.name,\r\n        _time: now(),\r\n        _field: \"factor_carga\",\r\n        _value: float(v: r.mean_kwh) / float(v: r.max_kwh)\r\n    }))\r\n  |> group()\n  |> sort(columns: [\"_value\"], desc: true)\r\n  |> yield(name: \"factor_carga\")\r\n",
          "refId": "A"
        }
      ],
      "title": "Factor de Carga por Dispositivo",
      "type": "barchart"
    },
