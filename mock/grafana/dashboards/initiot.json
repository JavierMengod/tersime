        {
          "datasource": {
            "type": "influxdb",
            "uid": "feg5i5n3pjq4gf"
          },
          "query": "option timezone = \"Europe/Madrid\"\r\n\r\nfrom(bucket: v.defaultBucket)\r\n  |> range(start: time(v: \"${start}\"), stop: time(v: \"${end}\"))\r\n  |> filter(fn: (r) =>\r\n      r._measurement == \"hourly\" and\r\n      r._field == \"kwh\" and\r\n      contains(value: r.name, set: ${dispositivos:json})\r\n    )\r\n  |> aggregateWindow(every: 1h, fn: mean, createEmpty: true)\r\n  |> map(fn: (r) => ({\r\n       _time: r._time,\r\n       name: r.name,\r\n       inactive: if exists r._value and r._value > 0.0 then 0 else 1\r\n    }))\r\n  |> group(columns: [\"name\"])\r\n  |> sort(columns: [\"_time\"])\r\n  |> difference(columns: [\"inactive\"], keepFirst: true)\r\n  |> filter(fn: (r) => r.inactive == 1 or r.inactive == -1)\r\n  |> map(fn: (r) => ({\r\n       _time: r._time,\r\n       name: r.name,\r\n       event: if r.inactive == 1 then \"start_inactivity\" else \"end_inactivity\"\r\n    }))\r\n  |> keep(columns: [\"_time\", \"name\", \"event\"])\r\n",
          "refId": "A"
        }
      ],
      "title": "Períodos sin Actividad",
      "type": "timeseries"
