            "type": "influxdb",
            "uid": "feg5i5n3pjq4gf"
          },
          "query": "import \"date\"\r\n\r\noption timezone = \"Europe/Madrid\"\r\n\r\nfrom(bucket: v.defaultBucket)\r\n  |> range(start: time(v: \"${start}\"), stop: time(v: \"${end}\"))\r\n  |> filter(fn: (r) =>\r\n      r._measurement == \"hourly\" and\r\n      r._field == \"kwh\" and\r\n      contains(value: r.name, set: ${dispositivos:json})\r\n    )\r\n  |> map(fn: (r) => ({ r with hour: date.hour(t: r._time) }))\r\n  |> group(columns: [\"name\", \"hour\"])\r\n  |> mean(column: \"_value\")\r\n  |> keep(columns: [\"name\", \"hour\", \"_value\"])\r\n  |> map(fn: (r) => ({\r\n      r with hourStr: if r.hour < 10 then \"0\" + string(v: r.hour) else string(v: r.hour)\r\n    }))\r\n  |> map(fn: (r) => ({\r\n       r with _time: time(v: \"2025-01-01T\" + r.hourStr + \":00:00+01:00\")\r\n     }))\r\n  |> rename(columns: {_value: \"mean_kwh\"})\r\n  |> keep(columns: [\"_time\", \"name\", \"mean_kwh\"])\r\n  |> group(columns: [\"name\"])\r\n  |> sort(columns: [\"_time\"])\r\n",
          "refId": "A"
        }
      ],
      "title": "Consumo Medio por Hora del Día",
      "type": "timeseries"
