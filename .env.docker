# ─────────────────────────────────────────────────────────────────────────────
# Tersime — Docker configuration template
# Copy this file to .env and adjust the values before running install.sh
# ─────────────────────────────────────────────────────────────────────────────

# ── Aplicación ────────────────────────────────────────────────────────────────
APP_NAME=Tersime
APP_ENV=production
APP_DEBUG=false
# URL pública completa con puerto (el navegador accede aquí)
APP_URL=http://localhost:8080

# ── Base de datos (SQLite — no cambiar) ───────────────────────────────────────
DB_CONNECTION=sqlite
DB_DATABASE=/var/www/database/database.sqlite

# ── InfluxDB ──────────────────────────────────────────────────────────────────
# URL interna que usa Laravel dentro de la red Docker
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_ORG=tersime
INFLUX_BUCKET=tersime
# Token de administrador (debe coincidir con DOCKER_INFLUXDB_INIT_ADMIN_TOKEN)
INFLUXDB_TOKEN=CHANGE_ME_influxdb_token

# ── InfluxDB init (solo para el contenedor InfluxDB en el primer arranque) ────
DOCKER_INFLUXDB_INIT_MODE=setup
DOCKER_INFLUXDB_INIT_USERNAME=admin
DOCKER_INFLUXDB_INIT_PASSWORD=CHANGE_ME_influx_admin_password
DOCKER_INFLUXDB_INIT_ORG=tersime
DOCKER_INFLUXDB_INIT_BUCKET=tersime
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN=CHANGE_ME_influxdb_token
DOCKER_INFLUXDB_INIT_RETENTION=0

# ── Grafana ───────────────────────────────────────────────────────────────────
# URL interna que usa Laravel para hacer proxy de /grafana/*
GRAFANA_BASE_URL=http://grafana:3000
# Se auto-genera en install.sh — no es necesario rellenarlo manualmente
GRAFANA_API_KEY=
GRAFANA_DATASOURCE_ID=1
# URL interna del renderer (llamado por Laravel para PDFs)
GRAFANA_RENDERER_URL=http://renderer:8081/render
GRAFANA_RENDERER_BASE_URL=http://grafana:3000
GRAFANA_RENDERER_TOKEN=

# ── Grafana admin (credenciales del contenedor Grafana) ───────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_grafana_password

# ── Predictor ─────────────────────────────────────────────────────────────────
PREDICTOR_URL=http://predictor:8888/predict

# ── Usuario admin de Tersime (primer usuario creado en la instalación) ─────────
TERSIME_ADMIN_USER=admin
TERSIME_ADMIN_PASSWORD=CHANGE_ME_app_password

# ── OpenRouter (opcional, para funciones de IA) ────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Mail (configuración posterior desde /configuracion/cuenta) ────────────────
MAIL_MAILER=log

# ── Sesión y caché ────────────────────────────────────────────────────────────
SESSION_DRIVER=file
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
