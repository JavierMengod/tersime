# ─────────────────────────────────────────────────────────────────────────────
# Tersime — plantilla de configuración Docker
# No edites este fichero directamente — install.sh genera .env a partir de él.
# ─────────────────────────────────────────────────────────────────────────────

# ── Aplicación ────────────────────────────────────────────────────────────────
APP_NAME=Tersime
APP_ENV=production
APP_DEBUG=false
APP_KEY=
# URL pública completa con puerto (el navegador accede aquí)
APP_URL=http://localhost:8080

# ── Base de datos (MySQL) ─────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=tersime
DB_USERNAME=tersime
DB_PASSWORD=CHANGE_ME_db_password
DB_ROOT_PASSWORD=CHANGE_ME_db_root_password

# ── InfluxDB ──────────────────────────────────────────────────────────────────
# URL interna que usa Laravel dentro de la red Docker
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_ORG=tersime
INFLUX_BUCKET=tersime
# Token de administrador (debe coincidir con DOCKER_INFLUXDB_INIT_ADMIN_TOKEN)
INFLUXDB_TOKEN=CHANGE_ME_influxdb_token

# ── InfluxDB init (solo para el contenedor InfluxDB en el primer arranque) ────
DOCKER_INFLUXDB_INIT_MODE=setup
DOCKER_INFLUXDB_INIT_USERNAME=admin
DOCKER_INFLUXDB_INIT_PASSWORD=CHANGE_ME_influx_admin_password
DOCKER_INFLUXDB_INIT_ORG=tersime
DOCKER_INFLUXDB_INIT_BUCKET=tersime
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN=CHANGE_ME_influxdb_token
DOCKER_INFLUXDB_INIT_RETENTION=0

# ── Grafana ───────────────────────────────────────────────────────────────────
# URL interna que usa Laravel para hacer proxy de /grafana/*
# Grafana sirve desde el subpath /grafana/ (GF_SERVER_SERVE_FROM_SUB_PATH=true)
GRAFANA_BASE_URL=http://grafana:3000/grafana
# Se auto-genera en install.sh — no es necesario rellenarlo manualmente
GRAFANA_API_KEY=
GRAFANA_DATASOURCE_ID=1
# URL interna del renderer (llamado por Laravel para PDFs)
GRAFANA_RENDERER_URL=http://renderer:8081/render
GRAFANA_RENDERER_BASE_URL=http://grafana:3000/grafana
# Token compartido entre el renderer y Laravel (AUTH_TOKEN en el contenedor renderer)
# install.sh genera un valor aleatorio; cámbialo si lo instalas manualmente
GRAFANA_RENDERER_TOKEN=CHANGE_ME_renderer_token

# ── Grafana admin (credenciales del contenedor Grafana) ───────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_grafana_password

# ── Predictor ─────────────────────────────────────────────────────────────────
PREDICTOR_URL=http://predictor:8888/predict

# ── Parámetros de coste y anomalías ───────────────────────────────────────────
# Coste estimado por kWh en euros (se muestra en el dashboard y en informes)
COSTE_ESTIMADO_KWH=0.15
# Multiplicador para detección de anomalías (desviaciones > N × σ)
MULTIPLICADOR_ANOMALIAS=3.5

# ── Usuario admin de Tersime (primer usuario creado en la instalación) ─────────
TERSIME_ADMIN_USER=admin
TERSIME_ADMIN_PASSWORD=CHANGE_ME_app_password

# ── OpenRouter (opcional, para funciones de IA) ────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Mail (configuración posterior desde /configuracion/cuenta) ────────────────
MAIL_MAILER=log

# ── Sesión y caché ────────────────────────────────────────────────────────────
SESSION_DRIVER=file
CACHE_DRIVER=file
QUEUE_CONNECTION=database
# SESSION_ENCRYPT cifra los datos de sesión en disco (recomendado en producción)
SESSION_ENCRYPT=true
# SESSION_SECURE_COOKIE solo funciona con HTTPS — cambiar a true si usas TLS
SESSION_SECURE_COOKIE=false
# Orígenes adicionales permitidos en CORS (además de APP_URL). Separados por coma si hay varios.
# CORS_ALLOWED_ORIGIN=https://app2.example.com

# ── Logging ───────────────────────────────────────────────────────────────────
# "docker" escribe en stderr (docker logs) + fichero rotativo diario (30 días)
LOG_CHANNEL=docker
LOG_LEVEL=notice

# ── Perfiles Docker Compose ───────────────────────────────────────────────────
# install.sh rellena este valor automáticamente (local-influxdb,local-grafana).
# Permite usar "docker compose up -d" sin especificar perfiles manualmente.
COMPOSE_PROFILES=
